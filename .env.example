# Copie para .env (não commitado) e preencha com sua chave da ElevenLabs.
# Documentação: https://elevenlabs.io/docs/api-reference/getting-started
ELEVENLABS_API_KEY=

# Voice ID padrão pra voiceover do Motion Reel. Você escolhe na sua conta
# (https://elevenlabs.io/app/voice-library). Algumas vozes PT-BR populares:
#   - "Sarah":    EXAVITQu4vr4xnSDxMaL  (multilíngue, voz feminina clara)
#   - "Charlie":  IKne3meq5aSn9XLyUdCD  (multilíngue, voz masculina jovem)
#   - "Brian":    nPczCjzI2devNBz1zQrb  (multilíngue, voz masculina grave)
# Você pode passar voiceId no scene.voiceover.voiceId pra usar outra por cena.
ELEVENLABS_DEFAULT_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# Modelo TTS — multilingue suporta PT-BR.
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
