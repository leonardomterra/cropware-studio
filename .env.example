# Copie para .env (não commitado) e preencha com sua chave da ElevenLabs.
# Documentação: https://elevenlabs.io/docs/api-reference/getting-started
#
# IMPORTANTE: voiceover requer plano Starter ($5/mo) ou superior — Free tier
# só libera premade voices via API, e nenhuma soa pt-BR nativo. Library voices
# (catálogo de vozes da comunidade) precisam de plano pago.
ELEVENLABS_API_KEY=

# Voice ID padrão pra voiceover do Motion Reel.
# Catálogo: https://elevenlabs.io/app/voice-library
#   - Cropware default:  RVmX026jCrF5VqUvpCk0  (voz Cropware, calma/editorial — library)
#   - "Sarah":           EXAVITQu4vr4xnSDxMaL  (premade, feminina, sotaque não-BR)
#   - "Charlie":         IKne3meq5aSn9XLyUdCD  (premade, masculina jovem)
#   - "Brian":           nPczCjzI2devNBz1zQrb  (premade, masculina grave)
# Por cena: scene.voiceover.voiceId e scene.voiceover.speakingRate
ELEVENLABS_DEFAULT_VOICE_ID=RVmX026jCrF5VqUvpCk0

# Modelo TTS — multilingue v2 suporta pt-BR com naturalidade.
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
